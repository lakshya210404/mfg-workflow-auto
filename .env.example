# Copy to .env and edit for your environment
POSTGRES_USER=mfg_user
POSTGRES_PASSWORD=mfg_pass
POSTGRES_DB=mfg_db
DATABASE_URL=postgresql://mfg_user:mfg_pass@localhost:5432/mfg_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production-use-a-long-random-string
LOG_LEVEL=INFO

# Automation thresholds (optional overrides)
DEFECT_RATE_THRESHOLD=0.15
DOWNTIME_ALERT_MINUTES=10
CYCLE_TIME_THRESHOLD_MINUTES=30.0
